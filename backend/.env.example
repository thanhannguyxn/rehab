# Backend environment configuration
# Copy this file to backend/.env and update values for your machine.

DATABASE_URL=mysql+pymysql://root:123456@localhost/rehab_v3

# JWT — use two DIFFERENT random secrets (e.g. openssl rand -hex 32)
SECRET_KEY=change-this-to-a-random-secret-key
REFRESH_SECRET_KEY=change-this-to-a-different-random-secret-key
JWT_ALGORITHM=HS256

# Token lifetimes
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — comma-separated list of allowed frontend origins (no wildcard when credentials=true)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:4173

# Set to true in production (requires HTTPS for secure cookies)
COOKIE_SECURE=false

# OpenAI-compatible API settings for chatbot agents
LLM_API_KEY=
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Email (SMTP) — for sending patient credentials after account creation
# Gmail: use App Password (https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=Rehab AI
