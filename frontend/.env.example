# Frontend environment configuration
# Copy this to frontend/.env and adjust for your setup.

# --- Local dev (HTTPS Vite + HTTP backend) ---
# Leave both empty → requests go through Vite proxy, fixing cross-scheme cookie issues.
VITE_API_BASE_URL=
VITE_WS_BASE_URL=

# --- Docker / direct connection ---
# Set to the backend URL if NOT using the Vite proxy.
# VITE_API_BASE_URL=http://localhost:8000
# VITE_WS_BASE_URL=ws://localhost:8000
